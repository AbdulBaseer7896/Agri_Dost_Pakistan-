# Copy this to .env for local development. NEVER commit the real .env file.

# Django
SECRET_KEY=django-insecure-change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# Database (leave blank for local SQLite, or paste Render Postgres External URL for production)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# Cloudinary - get free credentials at https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS - frontend URL(s), comma-separated
CORS_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000

# Production HTTPS (set False for local dev)
SECURE_SSL_REDIRECT=False
